{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/marketing/$1",
      "has": [
        { "type": "host", "value": "marketingvcard.lakshmivacuum.com" }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "/managingdirector/$1",
      "has": [
        { "type": "host", "value": "managingdirectorvcard.lakshmivacuum.com" }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "/ceo/$1",
      "has": [
        { "type": "host", "value": "ceovcard.lakshmivacuum.com" }
      ]
    }
  ]
}
